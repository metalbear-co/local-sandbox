{
  "operator": true,
  "target": {
    "path": "pod/pg-cloudsql-target",
    "namespace": "test-mirrord"
  },
  "feature": {
    "env": true,
    "fs": "local",
    "network": {
      "incoming": "off",
      "outgoing": true
    },
    "db_branches": [
      {
        "id": "cloudsql-branch",
        "type": "pg",
        "version": "17",
        "ttl_secs": 600,
        "creation_timeout_secs": 120,
        "connection": {
          "url": {
            "type": "env",
            "variable": "DATABASE_URL"
          }
        },
        "iam_auth": {
          "type": "gcp_cloud_sql",
          "credentials_json": {
            "type": "env",
            "variable": "GCP_CREDENTIALS_JSON"
          }
        },
        "copy": {
          "mode": "schema",
          "tables": {
            "users": {
              "filter": "name != 'Alice'"
            }
          }
        }
      }
    ]
  }
}