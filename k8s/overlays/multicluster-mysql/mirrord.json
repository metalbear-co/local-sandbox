{
  "target": {
    "path": "deploy/mysql",
    "namespace": "test-multicluster"
  },
  "feature": {
    "env": true,
    "fs": "local",
    "network": {
      "incoming": "off",
      "outgoing": true
    },
    "db_branches": [
      {
        "id": "mysql-multicluster-branch",
        "type": "mysql",
        "version": "8.0",
        "name": "mydatabase",
        "ttl_secs": 600,
        "creation_timeout_secs": 90,
        "connection": {
          "url": {
            "type": "env",
            "variable": "MYSQL_CONNECTION_URL"
          }
        },
        "copy": {
          "mode": "all"
        }
      }
    ]
  }
}