{
  "operator": true,
  "target": {
    "path": "pod/pg-rds-target",
    "namespace": "test-mirrord"
  },
  "feature": {
    "env": true,
    "fs": "local",
    "network": {
      "incoming": "off",
      "outgoing": true
    },
    "db_branches": [
      {
        "id": "rds-branch",
        "type": "pg",
        "version": "16",
        "ttl_secs": 600,
        "creation_timeout_secs": 120,
        "connection": {
          "url": {
            "type": "env",
            "variable": "DATABASE_URL"
          }
        },
        "iam_auth": {
          "type": "aws_rds",
          "region": {
            "type": "env",
            "variable": "MY_CUSTOM_AWS_REGION"
          },
          "access_key_id": {
            "type": "env",
            "variable": "MY_ACCESS_KEY"
          },
          "secret_access_key": {
            "type": "env",
            "variable": "MY_SECRET_KEY"
          }
        },
        "copy": {
          "mode": "schema"
        }
      }
    ]
  },
  "_comment": "This config uses custom environment variable names for all AWS credentials."
}