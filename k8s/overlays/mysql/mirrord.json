{
    "operator": true,
    "target": {
        "path": "pod/server-env-val",
        "namespace": "test-mirrord"
    },
    "feature": {
        "db_branches": [
            {
                "id": "mysql-dev-branch",
                "type": "mysql",
                "version": "8.0",
                "name": "user",
                "ttl_secs": 600,
                "creation_timeout_secs": 60,
                "connection": {
                    "url": {
                        "type": "env",
                        "variable": "MYSQL_CONNECTION_URL"
                    }
                },
                "copy": {
                    "mode": "schema",
                    "tables": {
                        "users": {
                            "filter": "name = 'Alice'"
                        },
                        "orders": {
                            "filter": "user = 'Alice'"
                        }
                    }
                }
            }
        ]
    }
}